<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Arial Black',Arial,sans-serif;background:#EEEEEE;}



/* TOPBAR */
.topbar{background:#1A1A1A;padding:14px 28px;display:flex;align-items:center;justify-content:space-between;border-bottom:3px solid #FF5A00;}
.logo-wrap{display:flex;flex-direction:column;gap:2px;}
.logo-text{font-size:32px;font-weight:900;color:white;letter-spacing:-1px;font-family:"Arial Black",Arial,sans-serif;line-height:1;}
.logo-amp{color:#FF5A00;}
.logo-sub{font-size:10px;color:rgba(255,255,255,.4);letter-spacing:.06em;text-transform:uppercase;font-family:Arial,sans-serif;margin-top:2px;}
.footer-logo-text{font-size:28px;font-weight:900;color:white;letter-spacing:-1px;font-family:"Arial Black",Arial,sans-serif;margin-bottom:6px;}
.nav{display:flex;gap:20px;}
.nav a{font-size:10px;color:rgba(255,255,255,.6);text-decoration:none;letter-spacing:.08em;text-transform:uppercase;font-family:Arial,sans-serif;transition:color .15s;}
.nav a:hover{color:#FF5A00;}

/* HERO COTIZADOR */
.hero{background:#1A1A1A;padding:44px 24px 52px;text-align:center;position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;top:-60px;right:-60px;width:280px;height:280px;border-radius:50%;background:#FF5A00;opacity:.05;}
.hero-eyebrow{font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.35);font-family:Arial,sans-serif;margin-bottom:14px;}
.hero-title{font-size:clamp(32px,5vw,54px);font-weight:900;color:white;text-transform:uppercase;line-height:1;letter-spacing:-1px;margin-bottom:10px;}
.hero-title span{color:#FF5A00;}

/* CARTEL 30 MIN */
.badge-30{display:inline-flex;align-items:center;gap:10px;background:#FF5A00;border-radius:50px;padding:12px 28px;margin:20px auto 28px;}
.badge-30-icon{font-size:22px;}
.badge-30-text{text-align:left;}
.badge-30-top{font-size:20px;font-weight:900;color:white;line-height:1;letter-spacing:-0.5px;}
.badge-30-sub{font-size:11px;color:rgba(255,255,255,.8);font-family:Arial,sans-serif;font-weight:400;letter-spacing:.02em;}

/* SEARCH */
.search-wrap{max-width:580px;margin:0 auto 16px;}
.search-bar{display:flex;border-radius:10px;overflow:hidden;border:2px solid #FF5A00;}
.search-bar input{flex:1;padding:15px 18px;background:#252525;border:none;color:white;font-family:Arial,sans-serif;font-size:14px;outline:none;}
.search-bar input::placeholder{color:rgba(255,255,255,.25);}
.search-bar button{padding:15px 26px;background:#FF5A00;border:none;color:white;font-size:12px;font-weight:900;font-family:'Arial Black',Arial,sans-serif;text-transform:uppercase;letter-spacing:.06em;cursor:pointer;white-space:nowrap;}
.search-bar button:hover{background:#E04E00;}

.hero-chips{display:flex;gap:7px;justify-content:center;flex-wrap:wrap;}
.hchip{font-size:10px;color:rgba(255,255,255,.4);background:rgba(255,255,255,.06);padding:5px 13px;border-radius:20px;font-family:Arial,sans-serif;cursor:pointer;transition:all .15s;}
.hchip:hover{background:rgba(255,255,255,.12);color:rgba(255,255,255,.7);}
.hchip span{color:#FF5A00;font-weight:700;}

.sticker{position:absolute;top:20px;right:20px;width:110px;height:110px;display:flex;align-items:center;justify-content:center;transform:rotate(12deg);z-index:10;filter:drop-shadow(0 4px 16px rgba(255,90,0,.35));}
.hero-wave{height:32px;background:#1A1A1A;position:relative;}
.hero-wave::after{content:'';position:absolute;bottom:0;left:0;right:0;height:32px;background:#EEEEEE;border-radius:50% 50% 0 0/100% 100% 0 0;}

/* BODY */
.body{padding:20px;max-width:1060px;margin:0 auto;}
.srv-label{font-size:10px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:#999;margin-bottom:12px;font-family:Arial,sans-serif;}
.srv-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:22px;}
@media(min-width:600px){.srv-grid{grid-template-columns:repeat(4,1fr);}}
.srv{background:white;border-radius:12px;padding:20px 12px 16px;text-align:center;cursor:pointer;transition:all .2s;border:3px solid transparent;position:relative;overflow:hidden;}
.srv::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;background:#E0E0E0;transition:background .2s;}
.srv.on::before{background:#FF5A00;}
.srv.on{border-color:#FF5A00;}
.srv:hover{border-color:#FFCCAA;}
.srv-illo{height:64px;display:flex;align-items:center;justify-content:center;margin-bottom:10px;}
.srv-name{font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:.04em;color:#1A1A1A;margin-bottom:2px;}
.srv-sub{font-size:10px;color:#999;font-family:Arial,sans-serif;}
.srv-count{font-size:10px;color:#FF5A00;font-weight:700;margin-top:5px;font-family:Arial,sans-serif;min-height:14px;}

.filter-row{display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;}
.filter-row input,.filter-row select{font-size:13px;padding:10px 12px;border:2px solid #E0E0E0;border-radius:8px;background:white;color:#1A1A1A;font-family:Arial,sans-serif;outline:none;transition:border .15s;}
.filter-row input{flex:1;min-width:180px;}
.filter-row input:focus,.filter-row select:focus{border-color:#FF5A00;}
.result-count{font-size:12px;color:#999;font-family:Arial,sans-serif;margin-bottom:14px;}
.result-count strong{color:#FF5A00;font-weight:900;}

.rates-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px;margin-bottom:28px;}
.rcard{background:white;border-radius:12px;overflow:hidden;border:2px solid transparent;transition:all .2s;}
.rcard:hover{border-color:#FF5A00;transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,0,0,.08);}
.rcard-bar{background:#FF5A00;padding:9px 16px;display:flex;align-items:center;justify-content:space-between;}
.rcard-carrier{font-size:11px;font-weight:700;color:white;text-transform:uppercase;letter-spacing:.07em;}
.rcard-badge{font-size:9px;background:rgba(0,0,0,.2);color:white;padding:3px 9px;border-radius:20px;text-transform:uppercase;font-family:Arial,sans-serif;}
.rcard-body{padding:16px;}
.rcard-route{font-size:16px;font-weight:900;color:#1A1A1A;text-transform:uppercase;line-height:1.15;margin-bottom:3px;}
.rcard-arrow{color:#FF5A00;margin:0 4px;}
.rcard-type{font-size:10px;color:#AAAAAA;text-transform:uppercase;letter-spacing:.06em;font-family:Arial,sans-serif;margin-bottom:14px;}
.prices{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px;}
.prices.solo{grid-template-columns:1fr;}
.pbox{background:#F5F5F5;border-radius:8px;padding:12px;text-align:center;}
.pval{font-size:24px;font-weight:900;color:#FF5A00;line-height:1;}
.pusd{font-size:12px;font-weight:700;color:#FF5A00;}
.plbl{font-size:10px;color:#AAAAAA;text-transform:uppercase;letter-spacing:.06em;margin-top:4px;font-family:Arial,sans-serif;}
.rcard-meta{display:flex;gap:6px;flex-wrap:wrap;}
.chip{font-size:11px;color:#666;background:#F0F0F0;padding:5px 10px;border-radius:20px;font-family:Arial,sans-serif;}

/* CTA FINAL */
.cta-band{background:#1A1A1A;border-radius:14px;padding:36px 24px;text-align:center;margin-bottom:24px;position:relative;overflow:hidden;}
.cta-band::before{content:'';position:absolute;top:-40px;right:-40px;width:180px;height:180px;border-radius:50%;background:#FF5A00;opacity:.08;}
.cta-30{display:inline-flex;align-items:center;gap:10px;background:#FF5A00;border-radius:50px;padding:10px 24px;margin-bottom:16px;}
.cta-30-val{font-size:22px;font-weight:900;color:white;letter-spacing:-0.5px;}
.cta-30-lbl{font-size:11px;color:rgba(255,255,255,.8);font-family:Arial,sans-serif;text-align:left;line-height:1.3;}
.cta-title{font-size:24px;font-weight:900;color:white;text-transform:uppercase;margin-bottom:8px;}
.cta-sub{font-size:13px;color:rgba(255,255,255,.4);line-height:1.7;font-family:Arial,sans-serif;margin-bottom:22px;}
.cta-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
.cbtn{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;border-radius:50px;font-size:13px;font-weight:900;text-decoration:none;text-transform:uppercase;letter-spacing:.06em;border:none;cursor:pointer;font-family:'Arial Black',Arial,sans-serif;}
.cbtn.ora{background:#FF5A00;color:white;}
.cbtn.wht{background:transparent;color:white;border:2px solid rgba(255,255,255,.25);}
.cbtn.ora:hover{background:#E04E00;}

.footer{background:#1A1A1A;padding:0;margin-top:32px;}
.footer-top{display:flex;align-items:flex-start;justify-content:space-between;gap:24px;padding:32px 28px;flex-wrap:wrap;border-top:3px solid #FF5A00;}
.footer-logo-wrap{display:flex;flex-direction:column;gap:4px;}
.footer-hashtag{font-size:13px;font-weight:900;color:#FF5A00;letter-spacing:.06em;font-family:"Arial Black",Arial,sans-serif;margin-top:4px;}
.footer-contact{display:flex;flex-direction:column;gap:12px;flex:1;min-width:200px;}
.footer-citem{display:flex;align-items:flex-start;gap:10px;font-size:12px;color:rgba(255,255,255,.7);font-family:Arial,sans-serif;line-height:1.5;text-decoration:none;transition:color .15s;}
.footer-citem:hover{color:#FF5A00;}
.footer-cicon{font-size:16px;flex-shrink:0;margin-top:1px;}
.footer-iso{display:flex;flex-direction:column;align-items:center;gap:8px;}
.footer-iso-label{font-size:10px;color:rgba(255,255,255,.4);font-family:Arial,sans-serif;text-align:center;line-height:1.5;max-width:120px;}
.footer-bottom{border-top:1px solid rgba(255,255,255,.08);padding:12px 28px;display:flex;align-items:center;justify-content:center;}
.vigencia-txt{font-size:10px;color:rgba(255,255,255,.25);letter-spacing:.05em;text-transform:uppercase;font-family:Arial,sans-serif;}
.empty{text-align:center;padding:50px;color:#CCC;font-family:Arial,sans-serif;font-size:14px;}
@media(max-width:500px){.nav{display:none;}}
</style>
</head>
